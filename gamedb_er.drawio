        <mxCell id="iYdfN-eE-mPeuNX01mk3-6" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;br&gt;&lt;table border=&quot;1&quot; width=&quot;100%&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse; font-size:12px;&quot;&gt;&lt;tbody&gt;&lt;tr&gt;&lt;th bgcolor=&quot;#eeeeee&quot; style=&quot;background-color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Нормальна форма&lt;/th&gt;&lt;th bgcolor=&quot;#eeeeee&quot; style=&quot;background-color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Критерій та підтвердження&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;1NF&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Атомарність значень. Усі поля (напр. &lt;i&gt;score, email&lt;/i&gt;) не містять списків або наборів даних.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;2NF&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Відсутність часткових залежностей. Усі неключові поля залежать від усього первинного ключа (ID).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;3NF&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Відсутність транзитивних залежностей. &lt;i&gt;developers&lt;/i&gt; та &lt;i&gt;publishers&lt;/i&gt; декомпоновані для уникнення дублювання даних про країни.&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="170" width="480" x="100" y="410" as="geometry" />
        </mxCell>
